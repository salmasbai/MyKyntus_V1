{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "documentation": {
        "ClusterId": "documentation",
        "Match": {
          "Path": "/api/documentation/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "documentation": {
        "Destinations": {
          "documentation": {
            "Address": "http://localhost:5002/"
          }
        }
      }
    }
  }
}
